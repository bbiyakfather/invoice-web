# ===========================================================================
# 환경변수 예시 (.env.example)
# 로컬: 이 파일을 .env.local 로 복사해 실제 값을 채우세요.
# Vercel: 아래 변수들을 Vercel 대시보드 > Settings > Environment Variables 에 등록하세요.
# ※ 비밀값(키/비밀번호/시크릿)은 절대 이 파일이나 저장소에 커밋하지 마세요.
# ===========================================================================

# --- Notion (필수) ---
# Notion 통합(Integration) 시크릿. "secret_" 또는 "ntn_" 로 시작.
# 발급: https://www.notion.so/my-integrations  (스코프: Production)
NOTION_API_KEY=

# 견적서 Notion 데이터베이스 ID (32자, 하이픈 없는 형태)  (스코프: Production)
NOTION_DATABASE_ID=

# (선택) 견적 "항목(items)" 전용 Notion 데이터베이스 ID (32자)
# 관리자 편집에서 '항목 신규 생성'을 사용할 때만 필요. 미설정 시 항목 추가만 비활성.
NOTION_ITEMS_DATABASE_ID=

# --- 관리자 인증 (필수) ---
# 관리자 로그인 비밀번호 (최소 8자, 기본/약한 값 금지)  (스코프: Production)
ADMIN_PASSWORD=

# 세션 서명용 시크릿 (정확히 32자). 생성: openssl rand -base64 24 | cut -c1-32
# (스코프: Production)
SESSION_SECRET=

# --- 애플리케이션 URL (프로덕션 필수) ---
# 견적서 공유 링크 생성에 사용. 프로덕션 실제 도메인(https://...)으로 설정.
# 미설정 시 Vercel 배포 URL(VERCEL_URL)로 폴백되나, 커스텀 도메인 사용 시 반드시 지정.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# (선택) 외부 노출용 앱 URL이 별도로 필요할 때.
NEXT_PUBLIC_APP_URL=
